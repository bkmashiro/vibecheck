{
  "name": "vibecheck",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:worker": "cd worker && wrangler dev",
    "dev:frontend": "cd frontend && vite",
    "deploy:worker": "cd worker && wrangler deploy",
    "deploy:frontend": "cd frontend && vite build && wrangler pages deploy dist --project-name vibecheck"
  }
}
